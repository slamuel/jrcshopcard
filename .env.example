# PostgreSQL (Neon, Supabase, Vercel Postgres, local Docker)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/jrc_shop_card?schema=public"

# NextAuth — generate with `openssl rand -base64 32`
AUTH_SECRET=""

# Vercel Blob (optional for local dev — leave empty to skip uploads)
BLOB_READ_WRITE_TOKEN=""

# Google Maps — browser key (Places / Maps JS); server key (Geocoding)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""
GOOGLE_MAPS_SERVER_API_KEY=""

# App URL
NEXTAUTH_URL="http://localhost:3000"

# Gemini — roof visualization on job detail (image generation; optional for local dev)
# GEMINI_IMAGE_MODEL="gemini-2.0-flash-preview-image-generation"
GEMINI_API_KEY=""
